# =============================================================================
#  .gitignore — ReHLDS Counter-Strike 1.6 server
# =============================================================================
#  Tracked: Dockerfile, docker-compose.yml, scripts/, config/, docs and
#  .env.example. Ignored: secrets, runtime server data, editor/OS noise.

# --- Secrets / local config --------------------------------------------------
# The real .env (RCON password, server name) is copied from .env.example and
# edited locally. .env.example IS tracked; the real .env must not be.
.env
.env.local
.env.*.local

# --- Host-specific Compose overrides -----------------------------------------
# docker-compose.override.yml is auto-merged by Compose; it and the fastdl/
# nginx config are host-specific and copied to the prod box by hand — never
# tracked, so the committed docker-compose.yml stays network-agnostic.
docker-compose.override.yml
fastdl/

# --- Runtime server data -----------------------------------------------------
# The serverfiles volume (DATA_DIR, default ./serverdata): the whole CS 1.6
# install plus maps, logs, bans and the generated Reunion salt — many GB,
# constantly mutated, and fully regenerable from the image. Source config
# lives in config/ instead. Mirrors the .dockerignore exclusions.
serverdata/
data/
*-data/

# --- Python (scripts/clear-execstack.py) -------------------------------------
__pycache__/
*.py[cod]

# --- Editors / IDEs ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS cruft ----------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Misc --------------------------------------------------------------------
*.log
*.bak
*.orig
