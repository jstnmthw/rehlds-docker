# =============================================================================
#  ReHLDS Counter-Strike 1.6 server — configuration
# =============================================================================
#  Copy this file to ".env" and edit it:   cp .env.example .env
#  Every value here is applied at container start — change it and run
#  `docker compose up -d`, no rebuild needed.
# =============================================================================

# --- Container / compose -----------------------------------------------------

# Name of the Docker container.
CONTAINER_NAME=rehlds-csserver

# Host directory for the serverfiles volume (maps, logs, admin lists, bans).
# Seeded from the image on first run. A relative path is resolved next to
# docker-compose.yml. Delete this directory to reset the server to a clean
# state on the next start.
DATA_DIR=./serverdata


# --- Networking --------------------------------------------------------------
# With network_mode: host (the default), the server binds these UDP ports
# directly on the host. Port-forward SERVER_PORT on your router to expose the
# server to the internet.

# Game traffic + A2S/Steam queries (the port players connect to).
SERVER_PORT=27015

# Client/RCON channel port.
CLIENT_PORT=27005


# --- Server identity ---------------------------------------------------------

# Name shown in the Steam server browser.
SERVER_NAME=ReHLDS Counter-Strike 1.6

# RCON (remote console) password. SET THIS to something strong — an empty
# value disables RCON. Do not use spaces or double-quotes.
RCON_PASSWORD=changeme-rcon-pass

# Join password. Leave empty for a public server.
SERVER_PASSWORD=

# Server admin contact (email or URL), shown in some server browsers.
SV_CONTACT=


# --- Master server / listing -------------------------------------------------

# 0 = internet server (listed on the Steam master server, joinable publicly).
# 1 = LAN only. Keep 0 for a public server.
SV_LAN=0

# Steam master-server region:
#   0 US-East  1 US-West  2 South America  3 Europe
#   4 Asia     5 Australia 6 Middle East   7 Africa   255 World
SV_REGION=255


# --- Gameplay ----------------------------------------------------------------

# Maximum number of player slots.
MAX_PLAYERS=16

# Map the server boots on.
DEFAULT_MAP=de_dust2


# --- Fast downloads (HTTP mirror) — optional ---------------------------------

# Public URL of an HTTP mirror of the cstrike/ asset files. When set, joining
# players download maps/models/sounds over HTTP instead of the slow in-game
# UDP transfer. Leave empty to disable (clients fall back to UDP download).
#
# This repo ships an optional FastDL mirror in docker-compose.override.yml
# (git-ignored, host-specific). If you use it, point this at the public
# https:// URL Traefik serves — straight at https://, since the GoldSrc
# downloader does not follow http->https redirects. Trailing slash is fine.
#   e.g. SV_DOWNLOADURL=https://fastdl.example.com/
SV_DOWNLOADURL=


# --- YaPB bots ---------------------------------------------------------------

# true  = load YaPB and fill the server with bots.
# false = no bots at all (YaPB is not loaded by Metamod).
BOTS_ENABLED=true

# Number of bots (interpreted per BOT_QUOTA_MODE).
BOT_QUOTA=6

# fill   = keep (humans + bots) at BOT_QUOTA
# normal = always BOT_QUOTA bots regardless of humans
# match  = bots scale to match human count
BOT_QUOTA_MODE=fill

# Bot skill: 0 = newbie ... 4 = expert.
BOT_DIFFICULTY=3


# --- Reunion (non-Steam clients) — optional ----------------------------------

# true = also accept protocol 47/48 non-Steam clients (Reunion Metamod plugin).
# false = Steam clients only.
REUNION_ENABLED=false

# Hash salt for non-Steam SteamID generation. Leave empty to auto-generate a
# random salt on first start (persisted in the volume). If you set one, use
# 32+ alphanumeric characters.
REUNION_HASH_SALT=

# How non-Steam (protocol 47/48) clients are treated:
#   3 = allow, assign STEAM_ id derived from IP (recommended)
#   1 = allow, expect a real/HW-generated STEAM_ id
#   5 = reject non-Steam clients
REUNION_NOSTEAM_CID=3


# --- Engine / performance ----------------------------------------------------

# Extra HLDS launch parameters.
#   -pingboost 1|2   network loop strategy (2 is lower-latency but kernel-
#                    sensitive; drop to 1, or remove, if you see instability)
#   +sys_ticrate N   server simulation rate cap
EXTRA_START_PARAMS=-pingboost 1 +sys_ticrate 1000
